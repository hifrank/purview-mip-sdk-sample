# Microsoft Entra App Registration
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# User identity (used for MIP SDK engine and Graph API user context)
USER_EMAIL=user@yourtenant.onmicrosoft.com
USER_ID=user-object-id-guid

# Sensitivity label to apply (get from --list-labels output)
LABEL_ID=your-label-id
